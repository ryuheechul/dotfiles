# -*- mode: sh; -*- vim: set ft=zsh:

# source this file (even multiple times when needed to make sure the order of path is ensured)

# avoid $PATH polluted by duplicates - also new ones take precedence
typeset -U path

# convinient way to print $PATH
alias printpath='echo ${path} | tr " " "\n"'

function _activate_brew() {
  # brew is a non-essential, personal convenience here - when nix is
  # available it covers everything essential (../brew/Brewfile is a
  # fallback only for when nix itself can't install, e.g. FileVault on a
  # non-T2 Intel Mac); brew is just for extra tools installed by hand.
  # So: silently do nothing if it's not found, same as before.
  #
  # covers both mac architectures like ../../bootstrap/foundation/darwin/essential.sh
  # does (arm64 -> /opt/homebrew, Intel -> /usr/local), plus linuxbrew.
  # Checked via plain path existence (fast) rather than `uname -m` (that
  # essential.sh does) - forking `uname`+`xargs` costs ~15ms here, same
  # order of magnitude as the /home/ tax below, not worth paying twice.
  # Order matters: on macOS, stat-ing anything under /home/ triggers the
  # autofs automounter before failing (~15-20ms even for a nonexistent
  # path), so check the fast, actually-relevant paths first and only fall
  # back to /home/linuxbrew/... (fast on a real Linux box, where /home is a
  # normal local directory) as a last resort.
  local brew_bin=/opt/homebrew/bin/brew # apple silicon
  test -x "${brew_bin}" || brew_bin=/usr/local/bin/brew # intel mac
  test -x "${brew_bin}" || brew_bin="/home/linuxbrew/.linuxbrew/bin/brew" # linux
  test -x "${brew_bin}" || return # none found - no brew installed

  # `brew shellenv`'s output (HOMEBREW_PREFIX/CELLAR/REPOSITORY/FPATH) is
  # static per install - only changes if brew itself gets reinstalled
  # elsewhere, essentially never - so cache the raw text ourselves and skip
  # re-spawning `brew` on every shell startup. `_evalcache` (the usual tool
  # for this in ./shell_ext) isn't available this early - this file loads
  # from .zshenv, well before zinit loads in .zshrc.
  local cache_file="${HOME}/.zsh-evalcache/brew-shellenv.sh"
  if test ! -s "${cache_file}"; then
    mkdir -p "${cache_file:h}" # don't assume this pre-exists
    "${brew_bin}" shellenv > "${cache_file}"
  fi
  source "${cache_file}"
}

_activate_brew

function add-to-path {
  test -n "${1}" && path=("${1}" ${path})
}

# to mitigate the issue of /etc/profile not sourced for the time being - https://github.com/nix-community/home-manager/issues/3681
test -z "${path_helper_manually_called}" &&
  test -x /usr/libexec/path_helper &&
  eval $(/usr/libexec/path_helper -s) && export path_helper_manually_called=1

# assuming path for nix is already set from ../env
test -n "${float_nix_path}" && add-to-path $(printpath | grep 'nix-profile')

# discover user specific binaries and scripts
add-to-path "${HOME}/.local/bin"

# actually this wouldn't work.
# so bootstrap script should be at its own repo
# and that should be sourced
# ---
# https://github.com/ryuheechul/bin will be clone to this
add-to-path "${HOME}/.local/my-bin"

# my custom scripts that should work on any platform
add-to-path "${my_dot_d}/bin/path/default"

# my custom scripts that should work on Linux
is-linux && add-to-path "${my_dot_d}/bin/path/linux"

# my custom scripts that should work on WSL
is-wsl && add-to-path "${my_dot_d}/bin/path/wsl"

# my custom scripts that should work on darwin
is-darwin && add-to-path "${my_dot_d}/bin/path/darwin"
# add path for ssh
is-ssh && add-to-path "${my_dot_d}/bin/path/ssh"

is-nixos && add-to-path "${my_dot_d}/bin/path/nixos"
