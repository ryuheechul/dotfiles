{
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "plan"
  },
  "model": "sonnet",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "notify-gui 'needs permissions' '[Claude Code]'"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "notify-gui 'is now idle' '[Claude Code]'"
          }
        ]
      },
      {
        "matcher": "auth_success",
        "hooks": [
          {
            "type": "command",
            "command": "notify-gui 'auth success' '[Claude Code]'"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "notify-gui 'has a question' '[Claude code]'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context-mode@context-mode": true,
    "mempalace@mempalace": true,
    "typescript-lsp@claude-plugins-official": true,
    "ponytail@ponytail": true,
    "lua-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    },
    "mempalace": {
      "source": {
        "source": "github",
        "repo": "MemPalace/mempalace"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "tui": "fullscreen",
  "theme": "dark-ansi",
  "agentPushNotifEnabled": true
}
