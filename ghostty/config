# vim: set ft=toml:
# although it's not toml syntax, it helps with highlighting

# doc:
# - https://ghostty.org/docs/config
# - https://ghostty.org/docs/config/reference

# favor over `fullscreen = true` at least on Linux
maximize = true
# enable the line below for macOS as the maximize would do nothing there
# fullscreen = true
window-decoration = auto
quit-after-last-window-closed = true
initial-command = "~/.config/dfs-rhc/bin/terminal/ghostty"
font-size = 15
# # somehow this was not working on my system:
# # it was due to the corruption in my system and was fixed by `fc-cache -r`;
# # but I still keep it uncommented to try out the default font from ghostty;
# # which is mentioned at https://ghostty.org/docs/config#zero-configuration-philosophy
# font-family = "FiraMono Nerd Font Mono"

clipboard-read = allow
app-notifications = no-clipboard-copy

# macOS treats Option as a dead-key modifier for accented chars by default,
# not Meta - Emacs (and any other terminal app relying on M- bindings) never
# sees it as such, unlike GUI Emacs.app which reads the raw macOS Option key
# directly. `true` maps both Option keys to Alt/Meta; use `left`/`right`
# instead to keep the other side free for macOS accent input (e.g. right for
# that, left for Meta)
#
# NOTE: this setting alone doesn't guarantee M- bindings work - a
# hardware-level macOS keyboard layout misconfiguration can silently break
# Option-as-Meta even with this set correctly. If M-x etc. ever go dead
# again, check the keyboard layout first - see
# ../emacs.d/doom.d/known-issues.org
macos-option-as-alt = true

# thanks to https://github.com/ghostty-org/ghostty/discussions/2811
# for linux (Gnome)
keybind = performable:shift+insert=paste_from_clipboard
# with above, now the paste from clipboard finally works as expected

